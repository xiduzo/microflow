{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run build:wasm && vite dev",
    "build": "bun run build:wasm && vite build",
    "build:wasm": "bun run build:wasm:codegen && bun run build:wasm:firmata && bun run build:wasm:runtime",
    "build:wasm:codegen": "wasm-pack build ../../crates/microflow-codegen-wasm --target web --out-dir ../../apps/web/src/lib/codegen/generated",
    "build:wasm:firmata": "wasm-pack build ../../crates/microflow-firmata-wasm --target web --out-dir ../../apps/web/src/lib/firmata/generated",
    "build:wasm:runtime": "wasm-pack build ../../crates/microflow-runtime-wasm --target web --out-dir ../../apps/web/src/lib/runtime/generated",
    "build:app": "vite build",
    "serve": "vite preview",
    "start": "vite",
    "check-types": "tsc --noEmit",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "sh -c 'set -a && . ./.env && set +a && tauri build'",
    "codegen": "bun run scripts/codegen-node-registry.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@microflow/api": "workspace:*",
