    "@microflow/collab": "workspace:*",
    "@microflow/env": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "@polar-sh/better-auth": "catalog:",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-hotkeys": "^0.9.1",
    "@tanstack/react-pacer": "^0.20.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.167.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "^11.13.3",
    "@tscircuit/eval": "^0.0.716",
    "@tscircuit/schematic-autolayout": "^0.0.6",
    "@tscircuit/schematic-viewer": "^2.0.58",
