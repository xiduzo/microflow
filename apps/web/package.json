    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "catalog:",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "leva": "^0.10.1",
    "lib0": "^0.2.99",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "motion": "^12.36.0",
    "mqtt": "^5.15.1",
