{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.4.2",
    "@microflow/api": "workspace:*",
    "@microflow/auth": "workspace:*",
    "@microflow/collab": "workspace:*",
    "@microflow/db": "workspace:*",
    "@microflow/env": "workspace:*",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "^4.11.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@microflow/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.20.1",
    "typescript": "catalog:"
  }
}
